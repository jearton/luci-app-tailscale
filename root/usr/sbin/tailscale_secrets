#!/bin/sh

set -eu

SECRETS_FILE="${TAILSCALE_SECRETS_FILE:-/etc/tailscale/luci-secrets.json}"
JQ_CMD="${JQ_CMD:-jq}"
UCI_CMD="${UCI_CMD:-uci}"
umask 077

fail() {
	printf '%s\n' "$*" >&2
	exit 1
}

normalize_api_url() {
	url="${1:-http://127.0.0.1:3000}"
	[ -n "$url" ] || url='http://127.0.0.1:3000'
	while [ "${url%/}" != "$url" ]; do
		url="${url%/}"
	done
	case "$url" in
		http://?*|https://?*) ;;
		*) return 1 ;;
	esac
	printf '%s\n' "$url"
}

valid_key() {
	case "$1" in
		authkey|adguard_password|adguard_api_url|adguard_username) return 0 ;;
		*) return 1 ;;
	esac
}

secrets_dir() {
	dir="${SECRETS_FILE%/*}"
	[ "$dir" != "$SECRETS_FILE" ] || dir='.'
	printf '%s\n' "$dir"
}

ensure_secrets_dir() {
	dir="$(secrets_dir)"
	[ ! -L "$dir" ] || fail "refusing symlinked secrets directory"
	[ -d "$dir" ] || mkdir -p "$dir"
	chmod 0700 "$dir"
}

validate_existing_file() {
	[ ! -L "$SECRETS_FILE" ] || fail "refusing symlinked secrets file"
	[ ! -e "$SECRETS_FILE" ] || "$JQ_CMD" -e 'type == "object"' "$SECRETS_FILE" >/dev/null
}

merge_update() (
	update_file="$1"
	ensure_secrets_dir
	validate_existing_file
	dir="$(secrets_dir)"
	old_file="$SECRETS_FILE"
	old_tmp=
	target_tmp="$(mktemp "$dir/.luci-secrets.XXXXXX")"
	cleanup_merge() {
		rm -f "$target_tmp"
		[ -z "$old_tmp" ] || rm -f "$old_tmp"
	}
	trap cleanup_merge 0 1 2 15
	if [ ! -e "$old_file" ]; then
		old_tmp="$(mktemp "$dir/.luci-secrets-old.XXXXXX")"
		printf '%s\n' '{}' >"$old_tmp"
		old_file="$old_tmp"
	fi
	"$JQ_CMD" -s '.[0] * .[1]' "$old_file" "$update_file" >"$target_tmp"
	chmod 0600 "$target_tmp"
	mv -f "$target_tmp" "$SECRETS_FILE"
	target_tmp=
)

get_value() {
	key="$1"
	valid_key "$key" || fail "invalid secret key"
	validate_existing_file
	[ -f "$SECRETS_FILE" ] || return 1
	"$JQ_CMD" -er --arg key "$key" '.[$key] | select(type == "string")' "$SECRETS_FILE"
}

get_required_value() {
	value="$(get_value "$1")" || return 1
	[ -n "$value" ] || return 1
	printf '%s\n' "$value"
}

has_value() {
	get_required_value "$1" >/dev/null 2>&1
}

set_authkey() (
	ensure_secrets_dir
	update_file="$(mktemp "$(secrets_dir)/.luci-secrets-update.XXXXXX")"
	cleanup_update() {
		rm -f "$update_file"
	}
	trap cleanup_update 0 1 2 15
	"$JQ_CMD" -Rse 'select(length > 0) | {authkey: .}' >"$update_file" || fail "auth key must not be empty"
	merge_update "$update_file"
)

set_adguard() (
	ensure_secrets_dir
	update_file="$(mktemp "$(secrets_dir)/.luci-secrets-update.XXXXXX")"
	cleanup_update() {
		rm -f "$update_file"
	}
	trap cleanup_update 0 1 2 15
	"$JQ_CMD" -ce '
		if (
			type == "object" and
			(.password | type == "string" and length > 0) and
			(.api_url | type == "string" and test("^https?://.+")) and
			(.username | type == "string")
		) then {
			adguard_password: .password,
			adguard_api_url: (.api_url | sub("/+$"; "")),
			adguard_username: .username
		} else error("invalid AdGuard credential payload") end
	' >"$update_file" || fail "invalid AdGuard credential payload"
	merge_update "$update_file"
)

matches_adguard() {
	requested_url="$(normalize_api_url "${1:-}")"
	requested_user="${2:-}"
	has_value adguard_password || return 1
	bound_url="$(get_value adguard_api_url)" || return 1
	bound_user="$(get_value adguard_username)" || return 1
	[ "$requested_url" = "$(normalize_api_url "$bound_url")" ] && [ "$requested_user" = "$bound_user" ]
}

adguard_password_for() {
	matches_adguard "${1:-}" "${2:-}" || return 1
	get_required_value adguard_password
}

write_migration_adguard_payload() (
	password="$1"
	api_url="$2"
	username="$3"
	dir="$(secrets_dir)"
	password_file="$(mktemp "$dir/.luci-migrate-password.XXXXXX")"
	api_url_file="$(mktemp "$dir/.luci-migrate-url.XXXXXX")"
	username_file="$(mktemp "$dir/.luci-migrate-user.XXXXXX")"
	cleanup_migration_payload() {
		rm -f "$password_file" "$api_url_file" "$username_file"
	}
	trap cleanup_migration_payload 0 1 2 15
	printf '%s' "$password" >"$password_file"
	printf '%s' "$api_url" >"$api_url_file"
	printf '%s' "$username" >"$username_file"
	"$JQ_CMD" -nc \
		--rawfile password "$password_file" \
		--rawfile api_url "$api_url_file" \
		--rawfile username "$username_file" \
		'{password:$password,api_url:$api_url,username:$username}' | set_adguard
)

migrate_legacy() {
	ensure_secrets_dir
	auth_present=0
	adguard_present=0
	legacy_authkey=
	legacy_adguard_password=
	if legacy_authkey="$($UCI_CMD -q get tailscale.settings.authkey 2>/dev/null)"; then
		auth_present=1
	fi
	if legacy_adguard_password="$($UCI_CMD -q get tailscale.settings.adguard_password 2>/dev/null)"; then
		adguard_present=1
	fi

	if [ "$auth_present" = "1" ] && [ -n "$legacy_authkey" ] && ! has_value authkey; then
		printf '%s' "$legacy_authkey" | set_authkey
	fi
	if [ "$adguard_present" = "1" ] && [ -n "$legacy_adguard_password" ] && ! has_value adguard_password; then
		legacy_api_url="$($UCI_CMD -q get tailscale.settings.adguard_api_url 2>/dev/null || true)"
		legacy_username="$($UCI_CMD -q get tailscale.settings.adguard_username 2>/dev/null || true)"
		legacy_api_url="$(normalize_api_url "$legacy_api_url")"
		write_migration_adguard_payload "$legacy_adguard_password" "$legacy_api_url" "$legacy_username"
	fi

	changed=0
	if [ "$auth_present" = "1" ]; then
		[ -z "$legacy_authkey" ] || has_value authkey || fail "failed to migrate legacy auth key"
		$UCI_CMD -q delete tailscale.settings.authkey || true
		changed=1
	fi
	if [ "$adguard_present" = "1" ]; then
		[ -z "$legacy_adguard_password" ] || has_value adguard_password || fail "failed to migrate legacy AdGuard password"
		$UCI_CMD -q delete tailscale.settings.adguard_password || true
		changed=1
	fi
	[ "$changed" = "0" ] || $UCI_CMD commit tailscale
}

case "${1:-}" in
	get)
		get_required_value "${2:-}"
		;;
	has)
		has_value "${2:-}"
		;;
	set-authkey)
		set_authkey
		;;
	set-adguard)
		set_adguard
		;;
	matches-adguard)
		matches_adguard "${2:-}" "${3:-}"
		;;
	adguard-password-for)
		adguard_password_for "${2:-}" "${3:-}"
		;;
	migrate)
		migrate_legacy
		;;
	*)
		fail "usage: $0 get|has|set-authkey|set-adguard|matches-adguard|adguard-password-for|migrate"
		;;
esac

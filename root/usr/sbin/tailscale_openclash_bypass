#!/bin/sh
set -u

OPENCLASH_INIT="${OPENCLASH_INIT:-/etc/init.d/openclash}"
OPENCLASH_HOOK_FILE="${OPENCLASH_HOOK_FILE:-/etc/openclash/custom/openclash_custom_firewall_rules.sh}"
LOCK_FILE="${LOCK_FILE:-/var/lock/tailscale-openclash-bypass.lock}"
UCI_BIN="${UCI_BIN:-uci}"
NFT_BIN="${NFT_BIN:-nft}"
JQ_BIN="${JQ_BIN:-jq}"
LOGGER_CMD="${LOGGER_CMD:-logger}"

BEGIN_MARKER='# BEGIN luci-app-tailscale 托管：Tailscale 绕过 OpenClash'
END_MARKER='# END luci-app-tailscale 托管：Tailscale 绕过 OpenClash'
HOOK_TEMP_FILE=
NFT_TEMP_FILE=
NFT_CACHE_DIR=

cleanup_tracked_temps() {
	[ -z "$HOOK_TEMP_FILE" ] || rm -f "$HOOK_TEMP_FILE"
	[ -z "$NFT_TEMP_FILE" ] || rm -f "$NFT_TEMP_FILE"
	[ -z "$NFT_CACHE_DIR" ] || rm -rf "$NFT_CACHE_DIR"
}

trap cleanup_tracked_temps EXIT
trap 'exit 1' HUP INT TERM

managed_block() {
	cat <<'EOF'
# BEGIN luci-app-tailscale 托管：Tailscale 绕过 OpenClash
if test -x /usr/sbin/tailscale_openclash_bypass; then
	/usr/sbin/tailscale_openclash_bypass apply
fi
# END luci-app-tailscale 托管：Tailscale 绕过 OpenClash
EOF
}

openclash_installed() { test -x "$OPENCLASH_INIT"; }
log_error() { "$LOGGER_CMD" -p daemon.err -t tailscale_openclash_bypass "$*"; }

marker_offsets() {
	file="$1"
	[ ! -e "$file" ] && { printf 'absent\n'; return 0; }
	[ -f "$file" ] || return 1
	LC_ALL=C awk -v begin_marker="$BEGIN_MARKER" -v end_marker="$END_MARKER" '
		BEGIN {
			offset = 0
			begin_count = 0
			end_count = 0
		}
		{
			if ($0 == begin_marker) {
				begin_count++
				begin_offset = offset
			}
			if ($0 == end_marker) {
				end_count++
				end_offset = offset
			}
			offset += length($0) + 1
		}
		END {
			if (begin_count == 0 && end_count == 0) {
				print "absent"
				exit 0
			}
			if (begin_count != 1 || end_count != 1 || begin_offset >= end_offset)
				exit 1
			printf "present|%d|%d\n", begin_offset, end_offset
		}
	' "$file"
}

marker_state() {
	offsets="$(marker_offsets "$1")" || return 1
	printf '%s\n' "${offsets%%|*}"
}

file_mode() {
	stat -c '%a' "$1" 2>/dev/null || stat -f '%Lp' "$1"
}

file_owner() {
	stat -c '%u:%g' "$1" 2>/dev/null || stat -f '%u:%g' "$1"
}

byte_at() {
	dd if="$1" bs=1 skip="$2" count=1 2>/dev/null | od -An -tx1 | tr -d '[:space:]'
}

shebang_size() {
	first_line="$(head -n 1 "$1")"
	case "$first_line" in
		'#!'*) ;;
		*) return 1 ;;
	esac

	size="$(head -n 1 "$1" | wc -c | tr -d '[:space:]')"
	[ "$size" -gt 0 ] || return 1
	[ "$(byte_at "$1" $((size - 1)))" = 0a ] || return 1
	printf '%s\n' "$size"
}

new_hook_temp_file() {
	directory="$(dirname "$OPENCLASH_HOOK_FILE")"
	HOOK_TEMP_FILE="$(mktemp "$directory/.tailscale-openclash-hook.XXXXXX")" || return 1
}

discard_hook_temp() {
	[ -z "$HOOK_TEMP_FILE" ] || rm -f "$HOOK_TEMP_FILE"
	HOOK_TEMP_FILE=
}

finish_replacement() {
	mode="$1"
	owner="$2"

	if ! sh -n "$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if [ -n "$owner" ] && ! chown "$owner" "$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if ! chmod "$mode" "$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if ! mv -f "$HOOK_TEMP_FILE" "$OPENCLASH_HOOK_FILE"; then
		discard_hook_temp
		return 1
	fi
	HOOK_TEMP_FILE=
}

reconcile_hook() {
	if [ ! -e "$OPENCLASH_HOOK_FILE" ]; then
		mkdir -p "$(dirname "$OPENCLASH_HOOK_FILE")" || return 1
		new_hook_temp_file || return 1
		if ! printf '#!/bin/sh\n' >"$HOOK_TEMP_FILE"; then
			discard_hook_temp
			return 1
		fi
		if ! managed_block >>"$HOOK_TEMP_FILE"; then
			discard_hook_temp
			return 1
		fi
		finish_replacement 0755 ''
		return $?
	fi

	offsets="$(marker_offsets "$OPENCLASH_HOOK_FILE")" || return 1
	state="${offsets%%|*}"
	case "$state" in
		absent)
			prefix_offset="$(shebang_size "$OPENCLASH_HOOK_FILE")" || return 1
			suffix_offset="$prefix_offset"
			;;
		present)
			rest="${offsets#*|}"
			prefix_offset="${rest%%|*}"
			end_offset="${rest#*|}"
			end_length="$(printf '%s' "$END_MARKER" | wc -c | tr -d '[:space:]')"
			suffix_offset=$((end_offset + end_length))
			[ "$(byte_at "$OPENCLASH_HOOK_FILE" "$suffix_offset")" = 0a ] && \
				suffix_offset=$((suffix_offset + 1))
			;;
		*) return 1 ;;
	esac

	mode="$(file_mode "$OPENCLASH_HOOK_FILE")" || return 1
	owner="$(file_owner "$OPENCLASH_HOOK_FILE")" || return 1
	new_hook_temp_file || return 1

	if ! dd if="$OPENCLASH_HOOK_FILE" bs=1 count="$prefix_offset" 2>/dev/null >"$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if ! managed_block >>"$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if ! dd if="$OPENCLASH_HOOK_FILE" bs=1 skip="$suffix_offset" 2>/dev/null >>"$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi

	finish_replacement "$mode" "$owner"
}

cleanup_hook() {
	openclash_installed || return 0
	[ -e "$OPENCLASH_HOOK_FILE" ] || return 0

	offsets="$(marker_offsets "$OPENCLASH_HOOK_FILE")" || return 1
	state="${offsets%%|*}"
	[ "$state" = absent ] && return 0

	rest="${offsets#*|}"
	begin_offset="${rest%%|*}"
	end_offset="${rest#*|}"
	end_length="$(printf '%s' "$END_MARKER" | wc -c | tr -d '[:space:]')"
	suffix_offset=$((end_offset + end_length))
	[ "$(byte_at "$OPENCLASH_HOOK_FILE" "$suffix_offset")" = 0a ] && \
		suffix_offset=$((suffix_offset + 1))

	mode="$(file_mode "$OPENCLASH_HOOK_FILE")" || return 1
	owner="$(file_owner "$OPENCLASH_HOOK_FILE")" || return 1
	new_hook_temp_file || return 1

	if ! dd if="$OPENCLASH_HOOK_FILE" bs=1 count="$begin_offset" 2>/dev/null >"$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi
	if ! dd if="$OPENCLASH_HOOK_FILE" bs=1 skip="$suffix_offset" 2>/dev/null >>"$HOOK_TEMP_FILE"; then
		discard_hook_temp
		return 1
	fi

	finish_replacement "$mode" "$owner"
}

rule_specs() {
	cat <<'EOF'
openclash_mangle_output|luci-app-tailscale: Tailscale 标记流量绕过 OpenClash（mangle output）|meta mark & 0x00ff0000 == 0x00080000
openclash_output|luci-app-tailscale: Tailscale 标记流量绕过 OpenClash（output）|meta mark & 0x00ff0000 == 0x00080000
openclash_mangle|luci-app-tailscale: tailscale0 入站流量绕过 OpenClash（mangle）|iifname "tailscale0"
openclash|luci-app-tailscale: tailscale0 入站流量绕过 OpenClash（filter）|iifname "tailscale0"
EOF
}

feature_state() {
	if configured="$("$UCI_BIN" -q get tailscale_openclash.settings.enabled 2>/dev/null)"; then
		normalized="$(printf '%s' "$configured" | tr '[:upper:]' '[:lower:]')" || return 1
	else
		normalized=1
	fi

	case "$normalized" in
		1|true|on|yes|enabled) printf 'enabled\n' ;;
		0|false|off|no|disabled) printf 'disabled\n' ;;
		*) printf 'invalid\n' ;;
	esac
}

new_nft_temp_file() {
	mktemp "${TMPDIR:-/tmp}/tailscale-openclash-nft.XXXXXX"
}

new_nft_cache_dir() {
	mktemp -d "${TMPDIR:-/tmp}/tailscale-openclash-nft-cache.XXXXXX"
}

discard_nft_temp() {
	[ -z "$NFT_TEMP_FILE" ] || rm -f "$NFT_TEMP_FILE"
	NFT_TEMP_FILE=
}

discard_nft_cache() {
	[ -z "$NFT_CACHE_DIR" ] || rm -rf "$NFT_CACHE_DIR"
	NFT_CACHE_DIR=
}

nft_json_supported() {
	printf '%s\n' "$1" | "$JQ_BIN" -e '.nftables | type == "array"' >/dev/null 2>&1
}

table_has_chain() {
	table_json="$1"
	chain="$2"
	printf '%s\n' "$table_json" | "$JQ_BIN" -e --arg chain "$chain" '
		.nftables[] | .chain? |
		select(.family == "inet" and .table == "fw4" and .name == $chain)
	' >/dev/null 2>&1
}

all_target_chains_present() {
	table_json="$1"
	specs="$(rule_specs)"
	while IFS='|' read -r chain comment match; do
		table_has_chain "$table_json" "$chain" || return 1
	done <<EOF
$specs
EOF
}

refreshed_chain_state() {
	chain="$1"
	if ! refreshed_table_json="$("$NFT_BIN" -j list table inet fw4 2>/dev/null)"; then
		printf 'table-absent\n'
		return 0
	fi
	if ! nft_json_supported "$refreshed_table_json"; then
		printf 'unsupported\n'
		return 0
	fi
	if table_has_chain "$refreshed_table_json" "$chain"; then
		printf 'present\n'
	else
		printf 'absent\n'
	fi
}

owned_handles() {
	chain_json="$1"
	comment="$2"
	printf '%s' "$chain_json" | "$JQ_BIN" -r --arg comment "$comment" '
		.nftables[] | .rule? | select(.comment == $comment) | .handle
	'
}

cache_owned_handles() {
	cache_dir="$1"
	chain="$2"
	comment="$3"
	chain_json="$4"
	handles="$(owned_handles "$chain_json" "$comment")" || return 1
	handles_file="$cache_dir/$chain"
	: >"$handles_file" || return 1
	[ -n "$handles" ] || return 0

	while IFS= read -r handle || [ -n "$handle" ]; do
		case "$handle" in
			''|*[!0-9]*) return 1 ;;
		esac
		printf '%s\n' "$handle" >>"$handles_file" || return 1
	done <<EOF
$handles
EOF
}

append_cached_deletions() {
	cache_dir="$1"
	specs="$(rule_specs)"
	while IFS='|' read -r chain comment match; do
		handles_file="$cache_dir/$chain"
		[ -s "$handles_file" ] || continue
		while IFS= read -r handle || [ -n "$handle" ]; do
			printf 'delete rule inet fw4 %s handle %s\n' "$chain" "$handle" || return 1
		done <"$handles_file"
	done <<EOF
$specs
EOF
}

cached_handles_present() {
	cache_dir="$1"
	specs="$(rule_specs)"
	while IFS='|' read -r chain comment match; do
		[ -s "$cache_dir/$chain" ] && return 0
	done <<EOF
$specs
EOF
	return 1
}

append_managed_rules() {
	specs="$(rule_specs)"
	while IFS='|' read -r chain comment match; do
		printf 'insert rule inet fw4 %s %s counter comment "%s" return\n' \
			"$chain" "$match" "$comment" || return 1
	done <<EOF
$specs
EOF
}

apply_rules() {
	if ! table_json="$("$NFT_BIN" -j list table inet fw4 2>/dev/null)"; then
		log_error 'OpenClash nftables table inet fw4 is unavailable.' || true
		return 1
	fi
	if ! nft_json_supported "$table_json"; then
		log_error 'OpenClash nftables table JSON is unsupported.' || true
		return 1
	fi
	all_target_chains_present "$table_json" || return 0

	cache_dir="$(new_nft_cache_dir)" || return 1
	NFT_CACHE_DIR="$cache_dir"
	specs="$(rule_specs)"

	while IFS='|' read -r chain comment match; do
		if ! chain_json="$("$NFT_BIN" -j -a list chain inet fw4 "$chain" 2>/dev/null)"; then
			refreshed_state="$(refreshed_chain_state "$chain")" || refreshed_state=unsupported
			case "$refreshed_state" in
				absent|table-absent)
					discard_nft_cache
					return 0
					;;
				*)
					log_error "OpenClash nftables chain $chain could not be read." || true
					discard_nft_cache
					return 1
					;;
			esac
		fi
		if ! nft_json_supported "$chain_json"; then
			log_error "OpenClash nftables JSON is unsupported for chain $chain." || true
			discard_nft_cache
			return 1
		fi
		if ! cache_owned_handles "$cache_dir" "$chain" "$comment" "$chain_json"; then
			log_error "Failed to read owned OpenClash nftables rules from chain $chain." || true
			discard_nft_cache
			return 1
		fi
	done <<EOF
$specs
EOF

	NFT_TEMP_FILE="$(new_nft_temp_file)" || {
		discard_nft_cache
		return 1
	}
	if ! append_cached_deletions "$cache_dir" >"$NFT_TEMP_FILE"; then
		discard_nft_cache
		discard_nft_temp
		return 1
	fi
	discard_nft_cache
	if ! append_managed_rules >>"$NFT_TEMP_FILE"; then
		discard_nft_temp
		return 1
	fi
	if ! "$NFT_BIN" -f "$NFT_TEMP_FILE"; then
		log_error 'OpenClash nftables reconciliation transaction failed.' || true
		discard_nft_temp
		return 1
	fi
	discard_nft_temp
}

cleanup_rules() {
	if ! table_json="$("$NFT_BIN" -j list table inet fw4 2>/dev/null)"; then
		return 0
	fi
	if ! nft_json_supported "$table_json"; then
		log_error 'OpenClash nftables table JSON is unsupported.' || true
		return 1
	fi
	cache_dir="$(new_nft_cache_dir)" || return 1
	NFT_CACHE_DIR="$cache_dir"
	specs="$(rule_specs)"

	while IFS='|' read -r chain comment match; do
		: >"$cache_dir/$chain" || {
			discard_nft_cache
			return 1
		}
		table_has_chain "$table_json" "$chain" || continue
		if ! chain_json="$("$NFT_BIN" -j -a list chain inet fw4 "$chain" 2>/dev/null)"; then
			refreshed_state="$(refreshed_chain_state "$chain")" || refreshed_state=unsupported
			case "$refreshed_state" in
				absent) continue ;;
				table-absent)
					discard_nft_cache
					return 0
					;;
				*)
					log_error "OpenClash nftables chain $chain could not be read." || true
					discard_nft_cache
					return 1
					;;
			esac
		fi
		if ! nft_json_supported "$chain_json"; then
			log_error "OpenClash nftables JSON is unsupported for chain $chain." || true
			discard_nft_cache
			return 1
		fi
		if ! cache_owned_handles "$cache_dir" "$chain" "$comment" "$chain_json"; then
			log_error "Failed to read owned OpenClash nftables rules from chain $chain." || true
			discard_nft_cache
			return 1
		fi
	done <<EOF
$specs
EOF

	if ! cached_handles_present "$cache_dir"; then
		discard_nft_cache
		return 0
	fi
	NFT_TEMP_FILE="$(new_nft_temp_file)" || {
		discard_nft_cache
		return 1
	}
	if ! append_cached_deletions "$cache_dir" >"$NFT_TEMP_FILE"; then
		discard_nft_cache
		discard_nft_temp
		return 1
	fi
	discard_nft_cache
	if [ ! -s "$NFT_TEMP_FILE" ]; then
		discard_nft_temp
		return 0
	fi
	if ! "$NFT_BIN" -f "$NFT_TEMP_FILE"; then
		log_error 'OpenClash nftables cleanup transaction failed.' || true
		discard_nft_temp
		return 1
	fi
	discard_nft_temp
}

cleanup_all() {
	result=0
	cleanup_hook
	cleanup_result=$?
	[ "$cleanup_result" -eq 0 ] || result="$cleanup_result"
	cleanup_rules
	cleanup_result=$?
	[ "$result" -ne 0 ] || result="$cleanup_result"
	return "$result"
}

sync_all() {
	openclash_installed || return 0
	current_feature_state="$(feature_state)" || return 1
	case "$current_feature_state" in
		disabled)
			cleanup_all
			return $?
			;;
		invalid)
			log_error 'OpenClash bypass enabled setting is invalid.' || true
			return 1
			;;
		enabled) ;;
		*) return 1 ;;
	esac

	if ! sync_table_json="$("$NFT_BIN" -j list table inet fw4 2>/dev/null)"; then
		return 0
	fi
	nft_json_supported "$sync_table_json" || return 0
	reconcile_hook || return 1
	apply_rules
}

print_status_json() {
	state="$1"
	enabled="$2"
	openclash_present="$3"
	firewall4_supported="$4"
	hook="$5"
	rules_present="$6"
	message="$7"
	"$JQ_BIN" -nc \
		--arg state "$state" \
		--argjson enabled "$enabled" \
		--argjson openclash_present "$openclash_present" \
		--argjson firewall4_supported "$firewall4_supported" \
		--arg hook "$hook" \
		--argjson rules_present "$rules_present" \
		--arg message "$message" \
		'{state: $state, enabled: ($enabled == 1), openclash_present: ($openclash_present == 1), firewall4_supported: ($firewall4_supported == 1), hook: $hook, rules_present: $rules_present, message: $message}'
}

print_status() {
	if ! openclash_installed; then
		print_status_json absent 0 0 0 absent 0 'OpenClash is not installed.'
		return
	fi

	current_feature_state="$(feature_state)" || current_feature_state=invalid
	case "$current_feature_state" in
		enabled) enabled=1 ;;
		*) enabled=0 ;;
	esac
	if ! table_json="$("$NFT_BIN" -j list table inet fw4 2>/dev/null)" || ! nft_json_supported "$table_json"; then
		print_status_json unsupported "$enabled" 1 0 unknown 0 'firewall4/nftables support is unavailable.'
		return
	fi

	if [ "$current_feature_state" = invalid ]; then
		print_status_json error 0 1 1 error 0 'OpenClash bypass enabled setting is invalid.'
		return
	fi
	if [ "$current_feature_state" = disabled ]; then
		print_status_json disabled 0 1 1 unknown 0 'OpenClash bypass is disabled.'
		return
	fi

	if ! hook_state="$(marker_state "$OPENCLASH_HOOK_FILE")"; then
		print_status_json error 1 1 1 error 0 'Managed hook markers are malformed.'
		return
	fi
	case "$hook_state" in
		present) hook=managed ;;
		absent) hook=absent ;;
		*) print_status_json error 1 1 1 error 0 'Managed hook markers are malformed.'; return ;;
	esac

	if ! all_target_chains_present "$table_json"; then
		print_status_json waiting 1 1 1 "$hook" 0 'Waiting for OpenClash nftables chains.'
		return
	fi

	complete_rules=1
	rules_present=0
	specs="$(rule_specs)"
	while IFS='|' read -r chain comment match; do
		if ! chain_json="$("$NFT_BIN" -j -a list chain inet fw4 "$chain" 2>/dev/null)"; then
			refreshed_state="$(refreshed_chain_state "$chain")" || refreshed_state=unsupported
			case "$refreshed_state" in
				absent)
					print_status_json waiting 1 1 1 "$hook" "$rules_present" 'Waiting for OpenClash nftables chains.'
					return
					;;
				table-absent|unsupported)
					print_status_json unsupported 1 1 0 "$hook" "$rules_present" 'firewall4/nftables support is unavailable.'
					return
					;;
				*)
					print_status_json error 1 1 1 "$hook" "$rules_present" "OpenClash nftables chain $chain could not be read."
					return
					;;
			esac
		fi
		if ! nft_json_supported "$chain_json"; then
			print_status_json unsupported 1 1 0 "$hook" "$rules_present" 'firewall4/nftables support is unavailable.'
			return
		fi
		handles="$(owned_handles "$chain_json" "$comment")" || {
			print_status_json unsupported 1 1 0 "$hook" "$rules_present" 'firewall4/nftables support is unavailable.'
			return
		}
		chain_rules=0
		if [ -n "$handles" ]; then
			while IFS= read -r handle || [ -n "$handle" ]; do
				case "$handle" in
					''|*[!0-9]*)
						print_status_json error 1 1 1 "$hook" "$rules_present" 'OpenClash bypass rule ownership data is invalid.'
						return
						;;
				esac
				chain_rules=$((chain_rules + 1))
				rules_present=$((rules_present + 1))
			done <<EOF
$handles
EOF
		fi
		[ "$chain_rules" = 1 ] || complete_rules=0
	done <<EOF
$specs
EOF

	if [ "$hook" = managed ] && [ "$complete_rules" = 1 ] && [ "$rules_present" = 4 ]; then
		print_status_json active 1 1 1 managed 4 'OpenClash bypass is active.'
		return
	fi
	print_status_json error 1 1 1 "$hook" "$rules_present" 'OpenClash bypass configuration is incomplete.'
}

case "${1:-}" in
	status)
		print_status
		;;
	sync|reconcile-hook|apply|cleanup)
		exec 9>"$LOCK_FILE" || exit 1
		flock -x 9 || exit 1
		case "$1" in
			sync)
				sync_all
				;;
			reconcile-hook)
				openclash_installed || exit 0
				reconcile_hook
				;;
			apply)
				openclash_installed || exit 0
				current_feature_state="$(feature_state)" || current_feature_state=invalid
				case "$current_feature_state" in
					enabled) apply_rules ;;
					disabled) cleanup_rules ;;
					*) log_error 'OpenClash bypass enabled setting is invalid.' || true; exit 1 ;;
				esac
				;;
			cleanup)
				cleanup_all
				;;
		esac
		;;
	*)
		printf 'usage: %s {sync|reconcile-hook|apply|cleanup|status}\n' "$0" >&2
		exit 2
		;;
esac

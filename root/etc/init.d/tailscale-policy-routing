#!/bin/sh /etc/rc.common

START=91
USE_PROCD=1

PROG="${PROG:-/usr/sbin/tailscale_policy_routing}"

service_triggers() {
	procd_add_reload_trigger "tailscale_policy_routing"
}

start_service() {
	"$PROG" sync
}

reload_service() {
	start_service
}

stop_service() {
	# Persistent cleanup is reserved for an explicit disable or package removal.
	# A normal service stop must not erase the enabled UCI declaration.
	return 0
}
